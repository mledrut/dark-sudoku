{
  "manifest_version": 3,
  "name": "Dark Sudoku",
  "description": "Mode sombre pour sudoku.com — un clic sur l'icône pour activer/désactiver.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "action": {
    "default_title": "Dark Sudoku : activer/désactiver le mode sombre"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sudoku.com/*", "https://*.sudoku.com/*"],
      "css": ["dark.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
